<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <groupId>io.github.jordepic</groupId>
    <artifactId>StreamFusion-orc-baseline</artifactId>
    <version>1.0-SNAPSHOT</version>

    <!-- The ORC host-baseline parity test lives in its own module because Flink's ORC format drags in
         orc-core 1.5.6, whose generated protobuf code needs protobuf-java 2.5, while the main module's
         protobuf parity test needs flink-protobuf's protobuf-java 4.x. The two protobuf-java versions
         cannot share one classpath, and a Maven profile cannot remove the conflicting dependency — so
         the ORC baseline is isolated here, depending on the main artifact and its native library. Run
         it after the main module is installed:  (cd .. && mvn install -DskipTests) && mvn test  -->

    <properties>
        <maven.compiler.source>17</maven.compiler.source>
        <maven.compiler.target>17</maven.compiler.target>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
        <junit.version>5.10.2</junit.version>
        <flink.version>2.2.1</flink.version>
        <scala.binary.version>2.12</scala.binary.version>
        <!-- The native library is built by the main module; point the test loader at its output dir. -->
        <native.profile>debug</native.profile>
    </properties>

    <dependencies>
        <!-- The native ORC source under test, and the planner that substitutes it, live in the main
             module. Arrow comes through transitively (a compile dependency there). -->
        <dependency>
            <groupId>io.github.jordepic</groupId>
            <artifactId>StreamFusion</artifactId>
            <version>1.0-SNAPSHOT</version>
            <scope>test</scope>
        </dependency>

        <dependency>
            <groupId>org.junit.jupiter</groupId>
            <artifactId>junit-jupiter</artifactId>
            <version>${junit.version}</version>
            <scope>test</scope>
        </dependency>

        <!-- Flink table runtime/planner for the SQL harness (provided to the main module by the
             distribution; declared here because provided dependencies are not transitive). -->
        <dependency>
            <groupId>org.apache.flink</groupId>
            <artifactId>flink-table-api-java-bridge</artifactId>
            <version>${flink.version}</version>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>org.apache.flink</groupId>
            <artifactId>flink-table-planner_${scala.binary.version}</artifactId>
            <version>${flink.version}</version>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>org.apache.flink</groupId>
            <artifactId>flink-clients</artifactId>
            <version>${flink.version}</version>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>org.apache.flink</groupId>
            <artifactId>flink-connector-files</artifactId>
            <version>${flink.version}</version>
            <scope>test</scope>
        </dependency>
        <!-- The native planner references the Kafka source/decode classes while rewriting any plan
             (deciding whether a scan is a Kafka source), so these must be on the classpath even though
             the ORC test itself uses no Kafka. Provided to the main module by the distribution. -->
        <dependency>
            <groupId>org.apache.flink</groupId>
            <artifactId>flink-connector-kafka</artifactId>
            <version>5.0.0-2.2</version>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>org.apache.kafka</groupId>
            <artifactId>kafka-clients</artifactId>
            <version>3.7.1</version>
            <scope>test</scope>
        </dependency>

        <!-- The host baseline: Flink's ORC format, which pins orc-core 1.5.6 (protobuf-java 2.5). The
             native read path never touches orc-core; this is only for writing the comparison files. -->
        <dependency>
            <groupId>org.apache.flink</groupId>
            <artifactId>flink-orc</artifactId>
            <version>${flink.version}</version>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>com.google.protobuf</groupId>
            <artifactId>protobuf-java</artifactId>
            <version>2.5.0</version>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>org.apache.hadoop</groupId>
            <artifactId>hadoop-common</artifactId>
            <version>3.3.4</version>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>org.apache.hadoop</groupId>
            <artifactId>hadoop-mapreduce-client-core</artifactId>
            <version>3.3.4</version>
            <scope>test</scope>
        </dependency>
    </dependencies>

    <build>
        <plugins>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-surefire-plugin</artifactId>
                <version>3.2.5</version>
                <configuration>
                    <!-- The native library is built by the main module's cargo step. -->
                    <argLine>-Djava.library.path=${project.basedir}/../native/target/${native.profile} --add-opens=java.base/java.nio=ALL-UNNAMED --add-opens=java.base/java.lang=ALL-UNNAMED --add-opens=java.base/java.util=ALL-UNNAMED --add-opens=java.base/java.io=ALL-UNNAMED --add-opens=java.base/java.net=ALL-UNNAMED --add-opens=java.base/java.util.concurrent=ALL-UNNAMED --add-opens=java.base/java.util.concurrent.atomic=ALL-UNNAMED --add-opens=java.base/java.lang.reflect=ALL-UNNAMED --add-opens=java.base/sun.nio.ch=ALL-UNNAMED</argLine>
                </configuration>
            </plugin>
        </plugins>
    </build>
</project>
