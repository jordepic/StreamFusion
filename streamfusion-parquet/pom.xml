<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>io.github.jordepic</groupId>
        <artifactId>StreamFusion</artifactId>
        <version>1.0-SNAPSHOT</version>
    </parent>

    <artifactId>streamfusion-parquet</artifactId>

    <dependencies>
        <dependency>
            <groupId>io.github.jordepic</groupId>
            <artifactId>streamfusion-runtime</artifactId>
            <version>${project.version}</version>
            <optional>true</optional>
        </dependency>
    </dependencies>

    <build>
        <resources combine.self="override">
            <resource>
                <directory>${project.basedir}/src/main/resources</directory>
            </resource>
            <resource>
                <directory>${project.basedir}/../native/target/universal/parquet</directory>
                <targetPath>io/github/jordepic/streamfusion/native/parquet</targetPath>
                <includes>
                    <include>**/libstreamfusion_parquet.so</include>
                    <include>**/libstreamfusion_parquet.dylib</include>
                </includes>
            </resource>
        </resources>
        <plugins>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-shade-plugin</artifactId>
                <version>3.5.3</version>
                <executions>
                    <execution>
                        <id>attach-runtime-payload</id>
                        <configuration><skip>true</skip></configuration>
                    </execution>
                    <execution>
                        <phase>package</phase>
                        <goals><goal>shade</goal></goals>
                        <configuration>
                            <createDependencyReducedPom>false</createDependencyReducedPom>
                            <artifactSet>
                                <includes>
                                    <include>io.github.jordepic:streamfusion-runtime</include>
                                </includes>
                            </artifactSet>
                            <filters>
                                <filter>
                                    <artifact>io.github.jordepic:streamfusion-runtime</artifact>
                                    <includes>
                                        <include>io/github/jordepic/streamfusion/operator/NativeFileArrowBulkFormat*.class</include>
                                        <include>io/github/jordepic/streamfusion/operator/NativeParquetBulkWriterFactory*.class</include>
                                        <include>io/github/jordepic/streamfusion/operator/NativeParquetRollingPolicy*.class</include>
                                        <include>io/github/jordepic/streamfusion/operator/ParquetArrowBulkFormat*.class</include>
                                        <include>io/github/jordepic/streamfusion/operator/ParquetPartitionSplitOperator*.class</include>
                                        <include>io/github/jordepic/streamfusion/operator/ParquetSourceTimestamps*.class</include>
                                        <include>io/github/jordepic/streamfusion/planner/NativeParquetSinkExecNode*.class</include>
                                        <include>io/github/jordepic/streamfusion/planner/NativeParquetSourceExecNode*.class</include>
                                        <include>io/github/jordepic/streamfusion/planner/ParquetSinkMatcher*.class</include>
                                        <include>io/github/jordepic/streamfusion/planner/ParquetSinkTranslator*.class</include>
                                        <include>io/github/jordepic/streamfusion/planner/ParquetSourceMatcher*.class</include>
                                        <include>io/github/jordepic/streamfusion/planner/StreamPhysicalNativeParquetSink*.class</include>
                                        <include>io/github/jordepic/streamfusion/planner/StreamPhysicalNativeParquetSource*.class</include>
                                        <include>io/github/jordepic/streamfusion/parquet/**</include>
                                    </includes>
                                </filter>
                            </filters>
                        </configuration>
                    </execution>
                </executions>
            </plugin>
        </plugins>
    </build>
</project>
